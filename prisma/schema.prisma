generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  username        String
  password        String
  role            UserRole          @default(USER)
  bookings        Booking[]
  provider        ProviderProfile?
  providerRequest ProviderRequest[]
  notifications   Notification[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
}

model ProviderProfile {
  id           String         @id @default(uuid())
  userId       String         @unique
  businessName String
  description  String?
  location     String?
  isActive     Boolean        @default(true)
  availability Availability[]
  bookings     Booking[]
  user         User           @relation(fields: [userId], references: [id])
  services     Service[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt
}

model Service {
  id         String          @id @default(uuid())
  providerId String
  name       String
  duration   Int
  price      Float
  images     String[]
  bookings   Booking[]
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt
}

model Availability {
  id         String          @id @default(uuid())
  providerId String
  dayOfWeek  Int
  startTime  Int
  endTime    Int
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt

  @@index([providerId, dayOfWeek])
}

model Booking {
  id         String          @id @default(uuid())
  userId     String
  providerId String
  serviceId  String
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  status     BookingStatus   @default(PENDING)
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  service    Service         @relation(fields: [serviceId], references: [id])
  user       User            @relation(fields: [userId], references: [id])
  payment    Payment[]
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt

  @@index([providerId, date])
  @@index([userId])
  @@index([deletedAt])
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String
  amount          Float
  status          PaymentStatus
  provider        String
  paymentIntentId String
  booking         Booking       @relation(fields: [bookingId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
}

model ProviderRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  status RequestStatus @default(PENDING)

  provideName   String
  IDNumber      String
  fullName      String
  birthday      DateTime
  nationality   String
  location      String
  IDImage       String
  selfieIDImage String
  Portfolio     String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  message String

  type   NotificationType
  isRead Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

enum UserRole {
  USER
  PROVIDER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  PROVIDER_REQUEST
  BOOKING
  PAYMENT
  SYSTEM
}
